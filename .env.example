HUBSPOT_PRIVATE_APP_TOKEN=pat-...
HUBSPOT_DEFAULT_FROM_NAME=Your Community Name
HUBSPOT_DEFAULT_REPLY_TO=marketing@example.com

# Anthropic API key — used to extract content from uploaded flyer PDFs
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# Outlook / Microsoft 365 SMTP — used to send approval emails to salespeople
# Prerequisites:
#   1. SMTP AUTH must be enabled for your mailbox in the M365 admin center
#      (Users → your account → toggle "Authenticated SMTP")
#   2. If your account has MFA, generate an App Password instead of using your
#      regular password (account.microsoft.com → Security → App passwords)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=you@greatlakesmc.com
SMTP_PASS=your-app-password-or-regular-password
# Display name + address shown in the From field
SMTP_FROM=Your Name <you@greatlakesmc.com>

# Public URL of this app — used to generate magic links in approval emails
# Local dev: http://localhost:3000  |  Production: https://your-domain.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

HUBSPOT_PRIVATE_APP_TOKEN=pat-...

# Anthropic API key — used to extract content from uploaded flyer PDFs
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# Microsoft Graph (app-only) — used to send approval emails from an M365 mailbox.
# Setup: Entra ID → App registration → API permissions → Graph → Application → Mail.Send
# Grant admin consent, then create a client secret under Certificates & secrets.
GRAPH_TENANT_ID=your-directory-tenant-id
GRAPH_CLIENT_ID=your-application-client-id
GRAPH_CLIENT_SECRET=your-client-secret-value
# The licensed M365 mailbox to send as (must be covered by the app registration)
MAIL_FROM=you@greatlakesmc.com
# Optional: override the display name shown in the From field
MAIL_FROM_NAME=Eblast Drafter

# Public URL of this app — used to generate magic links in approval emails.
# Use a STABLE domain, not a per-deployment preview URL (those change on every deploy).
# Local dev: http://localhost:3000  |  Production: https://eblast-creator.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auto-injected by Vercel when Protection Bypass for Automation is enabled on the
# project (Project Settings → Deployment Protection). Do NOT set this manually —
# Vercel provides it at runtime. Used by lib/email.ts to let salespeople (who
# aren't on the Vercel team) click Approve/Request-Edits links without hitting
# the "You need access" SSO wall. Not needed locally.
# VERCEL_AUTOMATION_BYPASS_SECRET=

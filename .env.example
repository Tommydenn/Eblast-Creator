HUBSPOT_PRIVATE_APP_TOKEN=pat-...
HUBSPOT_DEFAULT_FROM_NAME=Your Community Name
HUBSPOT_DEFAULT_REPLY_TO=marketing@example.com

# Anthropic API key — used to extract content from uploaded flyer PDFs
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# Resend — used to send approval emails to salespeople
# Sign up at https://resend.com, get an API key from the dashboard
# For testing: set RESEND_FROM_ADDRESS to "Eblast Drafter <onboarding@resend.dev>" (no domain verification needed)
# For production: verify your domain at resend.com and set to e.g. "Eblast Drafter <drafts@greatlakesmc.com>"
RESEND_API_KEY=re_...
RESEND_FROM_ADDRESS=Eblast Drafter <onboarding@resend.dev>

# Public URL of this app — used to generate magic links in approval emails
# Local dev: http://localhost:3000  |  Production: https://your-domain.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
